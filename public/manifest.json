{
  "manifest_version": 3,
  "key": "",
  "name": "Y/TXT",
  "version": "1.0",
  "description": "Emulate entire algorithms with 1-2 sentences of plain text",
  "permissions": ["activeTab", "storage", "scripting", "nativeMessaging", "sidePanel"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://api.deepseek.com/*",
    "https://integrate.api.nvidia.com/*"
  ],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "icons": {
    "16": "logo.png",
    "32": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Y/TXT",
    "default_icon": {
      "16": "logo.png",
      "32": "logo.png",
      "48": "logo.png",
      "128": "logo.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
